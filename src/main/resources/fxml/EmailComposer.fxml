<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fx:controller="controllers.EmailComposerController"
            xmlns:fx="http://javafx.com/fxml" fitToWidth="true"
            styleClass="content-scroll" hbarPolicy="NEVER">
    <VBox spacing="24" styleClass="page-container" alignment="TOP_CENTER">
        <padding><Insets top="32" right="40" bottom="40" left="40"/></padding>

        <Button text="← Back" styleClass="tool-back-btn" onAction="#handleBack"/>

        <VBox spacing="6">
            <Label text="✉ Smart Email Composer" styleClass="page-title"
                   style="-fx-font-size: 26; -fx-font-weight: bold;"/>
            <Label text="Describe the email you need and AI will draft it for you"
                   styleClass="page-subtitle" style="-fx-font-size: 13; -fx-opacity: 0.7;"/>
        </VBox>

        <!-- Input form -->
        <VBox spacing="14">
            <HBox spacing="14">
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Recipient" style="-fx-font-size: 12; -fx-opacity: 0.7;"/>
                    <TextField fx:id="recipientField" promptText="Name or role (e.g. John, HR Manager)"
                               styleClass="text-input"/>
                </VBox>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Tone" style="-fx-font-size: 12; -fx-opacity: 0.7;"/>
                    <ComboBox fx:id="toneCombo" maxWidth="Infinity"/>
                </VBox>
            </HBox>

            <VBox spacing="6">
                <Label text="Purpose / What is this email about?" style="-fx-font-size: 12; -fx-opacity: 0.7;"/>
                <TextField fx:id="purposeField" promptText="e.g. Request for vacation next week, Follow up on project deadline..."
                           styleClass="text-input"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Key points to include (optional)" style="-fx-font-size: 12; -fx-opacity: 0.7;"/>
                <TextArea fx:id="keyPointsArea" promptText="Any specific details, dates, context..."
                          prefRowCount="4" wrapText="true" styleClass="tool-textarea" style="-fx-font-size: 13;"/>
            </VBox>

            <HBox spacing="12">
                <Button fx:id="composeBtn" text="✨ Compose Email" onAction="#handleCompose"
                        styleClass="btn-primary" style="-fx-font-size: 14;"/>
            </HBox>
        </VBox>

        <HBox fx:id="statusBar" spacing="10" alignment="CENTER" visible="false" managed="false">
            <ProgressIndicator prefWidth="20" prefHeight="20"/>
            <Label fx:id="statusLabel" text="" style="-fx-font-size: 13;"/>
        </HBox>

        <!-- Result -->
        <VBox fx:id="resultSection" spacing="14" visible="false" managed="false">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="✉ Draft Email" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="📋 Copy" onAction="#handleCopy" styleClass="btn-secondary"/>
                <Button text="🔄 Rewrite" onAction="#handleRewrite" styleClass="btn-primary"/>
            </HBox>
            <VBox styleClass="card">
                <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
                <Label fx:id="emailContent" wrapText="true"
                       style="-fx-font-size: 13; -fx-font-family: 'Segoe UI', sans-serif;"/>
            </VBox>
        </VBox>
    </VBox>
</ScrollPane>
