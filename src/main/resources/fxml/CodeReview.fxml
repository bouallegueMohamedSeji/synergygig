<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fx:controller="controllers.CodeReviewController"
            xmlns:fx="http://javafx.com/fxml" fitToWidth="true"
            styleClass="content-scroll" hbarPolicy="NEVER">
    <VBox spacing="24" styleClass="page-container" alignment="TOP_CENTER">
        <padding><Insets top="32" right="40" bottom="40" left="40"/></padding>

        <Button text="← Back" styleClass="tool-back-btn" onAction="#handleBack"/>

        <!-- Header -->
        <VBox spacing="6">
            <Label text="🔍 AI Code Review" styleClass="page-title"
                   style="-fx-font-size: 26; -fx-font-weight: bold;"/>
            <Label text="Paste your code and get instant AI-powered review with suggestions and improvements"
                   styleClass="page-subtitle" style="-fx-font-size: 13; -fx-opacity: 0.7;"/>
        </VBox>

        <!-- Language selector + input -->
        <VBox spacing="12">
            <HBox spacing="14" alignment="CENTER_LEFT">
                <Label text="Language:" style="-fx-font-size: 13;"/>
                <ComboBox fx:id="langCombo" promptText="Select language" prefWidth="180"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lineCount" text="0 lines" style="-fx-font-size: 11; -fx-opacity: 0.5;"/>
            </HBox>
            <TextArea fx:id="codeArea" promptText="Paste your code here..."
                      prefRowCount="16" wrapText="true" styleClass="tool-textarea"
                      style="-fx-font-family: 'Consolas', 'Courier New', monospace;"/>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Button fx:id="reviewBtn" text="✨ Review Code" onAction="#handleReview"
                        styleClass="btn-primary" style="-fx-font-size: 14;"/>
                <Button text="🗑 Clear" onAction="#handleClear" styleClass="btn-secondary"/>
            </HBox>
        </VBox>

        <!-- Status -->
        <HBox fx:id="statusBar" spacing="10" alignment="CENTER" visible="false" managed="false">
            <ProgressIndicator prefWidth="20" prefHeight="20"/>
            <Label fx:id="statusLabel" text="AI is reviewing..." style="-fx-font-size: 13;"/>
        </HBox>

        <!-- Result -->
        <VBox fx:id="resultSection" spacing="14" visible="false" managed="false">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <Label text="📊 Review Results" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="📋 Copy" onAction="#handleCopy" styleClass="btn-secondary" style="-fx-font-size: 12;"/>
            </HBox>
            <VBox styleClass="card" spacing="0">
                <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
                <Label fx:id="reviewContent" wrapText="true" style="-fx-font-size: 13;"/>
            </VBox>
        </VBox>
    </VBox>
</ScrollPane>
