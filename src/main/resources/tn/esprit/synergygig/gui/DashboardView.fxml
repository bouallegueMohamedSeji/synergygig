<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<StackPane
        xmlns="http://javafx.com/javafx/21"
        xmlns:fx="http://javafx.com/fxml"
        fx:controller="tn.esprit.synergygig.controllers.DashboardController">

    <!-- 🌌 Galaxy Background -->
    <Pane fx:id="animatedBackground"/>

    <!-- CONTENT -->
    <VBox spacing="30"
          alignment="TOP_LEFT"
          style="-fx-padding: 40;">

        <!-- HEADER + WEATHER -->
        <HBox alignment="CENTER_LEFT" spacing="20">

            <Label text="🚀 SynergyGig Dashboard"
                   style="-fx-text-fill: white;
                          -fx-font-size:26;
                          -fx-font-weight:bold;" />

            <Region HBox.hgrow="ALWAYS"/>

            <!-- WEATHER CARD -->
            <VBox fx:id="weatherCard"
                  prefWidth="180"
                  spacing="5"
                  alignment="CENTER"
                  style="-fx-background-color: rgba(255,255,255,0.08);
                         -fx-background-radius:20;
                         -fx-padding:15;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3),10,0,0,4);">

                <Label fx:id="weatherCity"
                       text="City"
                       style="-fx-text-fill: white;
                              -fx-font-size:14;
                              -fx-font-weight:bold;"/>

                <ImageView fx:id="weatherIcon"
                           fitHeight="60"
                           preserveRatio="true"/>

                <Label fx:id="weatherTemp"
                       text="0°C"
                       style="-fx-text-fill: #4da6ff;
                              -fx-font-size:22;
                              -fx-font-weight:bold;"/>

                <Label fx:id="weatherDesc"
                       text="Clear"
                       style="-fx-text-fill: white;
                              -fx-font-size:12;"/>
            </VBox>

        </HBox>

        <!-- STATS CARDS -->
        <HBox spacing="25">

            <VBox fx:id="cardTotal" styleClass="stat-card stat-total">
                <Label text="Total Offers" styleClass="stat-title"/>
                <Label fx:id="totalOffers" text="0" styleClass="stat-value"/>
            </VBox>

            <VBox fx:id="cardPublished" styleClass="stat-card stat-published">
                <Label text="Published" styleClass="stat-title"/>
                <Label fx:id="publishedOffers" text="0" styleClass="stat-value"/>
            </VBox>

            <VBox fx:id="cardProgress" styleClass="stat-card stat-progress">
                <Label text="In Progress" styleClass="stat-title"/>
                <Label fx:id="inProgressOffers" text="0" styleClass="stat-value"/>
            </VBox>

            <VBox fx:id="cardCompleted" styleClass="stat-card stat-completed">
                <Label text="Completed" styleClass="stat-title"/>
                <Label fx:id="completedOffers" text="0" styleClass="stat-value"/>
            </VBox>

            <VBox fx:id="cardCancelled" styleClass="stat-card stat-cancelled">
                <Label text="Cancelled" styleClass="stat-title"/>
                <Label fx:id="cancelledOffers" text="0" styleClass="stat-value"/>
            </VBox>

        </HBox>

        <!-- CHARTS + HEALTH -->
        <HBox spacing="50">

            <!-- LEFT SIDE -->
            <VBox spacing="30">

                <PieChart fx:id="offerPieChart"
                          prefWidth="400"/>

                <VBox spacing="15">

                    <Label text="📊 SynergyGig Health Score"
                           style="-fx-text-fill: white;
                                  -fx-font-size:20;
                                  -fx-font-weight:bold;" />

                    <ProgressBar fx:id="healthProgress"
                                 prefWidth="400"
                                 progress="0"/>

                    <Label fx:id="healthPercent"
                           text="0%"
                           style="-fx-text-fill: white;
                                  -fx-font-size:16;" />

                    <Label fx:id="healthBadge"
                           text=""
                           style="-fx-font-size:16;
                                  -fx-font-weight:bold;" />
                </VBox>

            </VBox>

            <!-- RIGHT SIDE -->
            <BarChart fx:id="offerBarChart"
                      prefWidth="650"
                      categoryGap="20"
                      barGap="5">
                <xAxis>
                    <CategoryAxis/>
                </xAxis>
                <yAxis>
                    <NumberAxis/>
                </yAxis>
            </BarChart>

        </HBox>

        <!-- NEWS SECTION -->
        <VBox spacing="10">

            <Label text="📰 Market Insights"
                   style="-fx-text-fill: white;
                          -fx-font-size:20;
                          -fx-font-weight:bold;" />

            <ListView fx:id="newsListView"
                      prefHeight="200"
                      style="-fx-background-color: rgba(255,255,255,0.05);
                             -fx-control-inner-background: #1a1a2e;
                             -fx-text-fill: #121826;" />
        </VBox>

    </VBox>

</StackPane>